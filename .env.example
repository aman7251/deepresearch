# Copy to .env and fill in. .env is gitignored — never commit real keys.

# ----- LLM provider -----
# "groq"  -> free OpenAI-compatible cloud (no GPU needed). Get a key: https://console.groq.com/keys
# "ollama"-> fully local models. Install: https://ollama.com  then `ollama pull llama3.1`
LLM_PROVIDER=groq

# Groq (used when LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# ----- Infra -----
REDIS_URL=redis://localhost:6379

# ----- Behaviour -----
# DEMO_MODE=1 serves a cached sample run so the UI works with zero keys.
DEMO_MODE=0
# Embedding model for the ephemeral RAG index (downloaded once from HuggingFace).
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# How many search results / pages to fetch per sub-question.
MAX_RESULTS_PER_QUERY=4
MAX_SUBQUESTIONS=4
API_BASE_URL=http://localhost:8000
